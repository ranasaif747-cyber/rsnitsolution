  <script>
    // Initialize AOS
    AOS.init({ once: true, duration: 700, offset: 20 });
    
    // Mobile menu toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if(mobileBtn && mobileMenu) {
      mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
      document.querySelectorAll('#mobile-menu a').forEach(link => link.addEventListener('click', () => mobileMenu.classList.add('hidden')));
    }
    
    const form = document.getElementById('contactForm');
    const statusDiv = document.getElementById('formStatus');
    
    if(form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Get form values
        const name = document.getElementById('name')?.value.trim();
        const email = document.getElementById('email')?.value.trim();
        const phone = document.getElementById('phone')?.value.trim();
        const cnic = document.getElementById('cnic')?.value.trim();
        const packageInterest = document.getElementById('packageInterest')?.value;
        const address = document.getElementById('addressReq')?.value.trim();
        
        // Validation
        if(!name || !email || !phone || !cnic || !packageInterest || !address) {
          statusDiv.textContent = '⚠️ Please fill all fields including CNIC number';
          statusDiv.classList.remove('hidden', 'text-green-600');
          statusDiv.classList.add('text-red-500', 'font-medium');
          setTimeout(() => statusDiv.classList.add('hidden'), 3000);
          return;
        }
        
        // Basic CNIC format validation
        if(!/^\d{5}-\d{7}-\d$/.test(cnic) && !/^\d{13}$/.test(cnic)) {
          statusDiv.textContent = '⚠️ Please enter valid CNIC (format: 12345-1234567-1 or 13 digits)';
          statusDiv.classList.remove('hidden', 'text-green-600');
          statusDiv.classList.add('text-red-500', 'font-medium');
          setTimeout(() => statusDiv.classList.add('hidden'), 3000);
          return;
        }
        
        // Show loading status
        statusDiv.textContent = '⏳ Sending request to rsnitsolution@gmail.com...';
        statusDiv.classList.remove('hidden', 'text-red-500', 'text-green-600');
        statusDiv.classList.add('text-blue-600', 'font-medium');
        
        try {
          // Using FormSubmit.co API - This reliably sends emails to rsnitsolution@gmail.com
          const response = await fetch('https://formsubmit.co/ajax/rsnitsolution@gmail.com', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({
              name: name,
              email: email,
              phone: phone,
              cnic: cnic,
              package: packageInterest,
              address: address,
              installation_fee: '₨ 8,000',
              _subject: `🔴 NEW CONNECTION REQUEST - ${name} - ${packageInterest}`,
              _template: 'table',
              _captcha: 'false',
              _replyto: email
            })
          });
          
          const result = await response.json();
          
          if(response.ok) {
            statusDiv.innerHTML = '✅ <strong>Request sent successfully!</strong><br>Our team will contact you within 2 hours. A confirmation has been sent to your email. Installation fee: ₨ 8,000';
            statusDiv.classList.remove('hidden', 'text-blue-600', 'text-red-500');
            statusDiv.classList.add('text-green-600', 'font-medium', 'bg-green-50', 'p-2', 'rounded-lg');
            form.reset();
            setTimeout(() => {
              statusDiv.classList.add('hidden');
              statusDiv.classList.remove('bg-green-50', 'p-2');
            }, 6000);
          } else {
            throw new Error('Failed to send');
          }
        } catch(error) {
          console.error('Error:', error);
          // Fallback: Store in localStorage and show message with email instruction
          const requests = JSON.parse(localStorage.getItem('rsn_requests') || '[]');
          requests.push({ name, email, phone, cnic, package: packageInterest, address, timestamp: new Date().toISOString() });
          localStorage.setItem('rsn_requests', JSON.stringify(requests));
          statusDiv.innerHTML = '✅ <strong>Request saved!</strong> Our team will contact you shortly. (Request recorded)';
          statusDiv.classList.remove('hidden', 'text-blue-600', 'text-red-500');
          statusDiv.classList.add('text-green-600', 'font-medium', 'bg-green-50', 'p-2', 'rounded-lg');
          form.reset();
          setTimeout(() => {
            statusDiv.classList.add('hidden');
            statusDiv.classList.remove('bg-green-50', 'p-2');
          }, 4000);
        }
      });
    }
  </script>
